<Project Sdk="MSBuild.Sdk.SqlProj/3.2.0">
    <PropertyGroup>
        <TargetFramework>net8.0</TargetFramework>
        <SqlServerVersion>Sql160</SqlServerVersion>

        <!-- where the SqlProj looks for PostDeploy scripts -->
        <PostDeployFolder>Post-Deployment</PostDeployFolder>
        <!-- filename of the Post-Deployment script -->
        <AutoPostDeployFile>AutoGeneratedPostDeploy.sql</AutoPostDeployFile>
        <!-- full MSBuild‐normalized path -->
        <AutoPostDeployPath>$(PostDeployFolder)\$(AutoPostDeployFile)</AutoPostDeployPath>

        <!-- Windows (using Visual Studio to build the project) -->
        <BashExe Condition="'$(OS)' == 'Windows_NT'">C:\Program Files\Git\bin\bash.exe</BashExe>
        <!-- Linux/macOS (Docker container) or on Windows if using dotnet build from th CLI-->
        <BashExe Condition="'$(OS)' != 'Windows_NT'">/bin/bash</BashExe>
    </PropertyGroup>

    <!-- 0) Include the shell script to generate the Post-Deployment script so MSBuild can run it -->
    <ItemGroup>
        <None Include="Post-Deployment\generate-postdeploy.sh" />
    </ItemGroup>

    <!-- 1) Generate the Post-Deployment script before we build -->
    <Target Name="GenerateAutoPostDeploy" BeforeTargets="BeforeBuild">
        <Exec WorkingDirectory="$(ProjectDir)" Command="&quot;$(BashExe)&quot; &quot;$(ProjectDir)Post-Deployment/generate-postdeploy.sh&quot; &quot;$(ProjectDir)$(AutoPostDeployPath)&quot;" />
    </Target>

    <!-- 2) Tell SqlProj to treat that generated file as a PostDeploy script -->
    <ItemGroup>
        <PostDeploy Include="$(AutoPostDeployPath)" />
    </ItemGroup>

    <!-- Include Tests and Tools even though they are not a part of the build -->
    <ItemGroup>
        <Content Remove="Tests\**\*.*" />
        <None Include="Tests\**\*.*" CopyToOutputDirectory="PreserveNewest" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\src\Eventuous.SqlServer.Database\Eventuous.SqlServer.Database.csproj" />
        <PackageReference Include="Microsoft.SqlServer.Dacpacs.Master" DacpacName="master" DatabaseVariableLiteralValue="master" SuppressMissingDependenciesErrors="False" />
    </ItemGroup>
</Project>