---
interface Props {
  alt: string;
  lightSrc: string;
  darkSrc: string;
}

const { alt, lightSrc, darkSrc } = Astro.props;
---

<picture class="themed-image">
  <img class="light-only" src={lightSrc} alt={alt} />
  <img class="dark-only" src={darkSrc} alt={alt} />
</picture>

<style>
  .themed-image img {
    max-width: 100%;
    height: auto;
    margin: 1rem 0;
  }
  .dark-only {
    display: none;
  }
  :global([data-theme='dark']) .light-only {
    display: none;
  }
  :global([data-theme='dark']) .dark-only {
    display: initial;
  }
</style>
