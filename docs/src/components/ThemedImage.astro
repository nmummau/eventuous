---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  alt: string;
  lightSrc: ImageMetadata;
  darkSrc: ImageMetadata;
}

const { alt, lightSrc, darkSrc } = Astro.props;
---

<picture class="themed-image">
  <Image class="light-only" src={lightSrc} alt={alt} />
  <Image class="dark-only" src={darkSrc} alt={alt} />
</picture>

<style>
  .themed-image img {
    max-width: 100%;
    height: auto;
    margin: 1rem 0;
  }
  .dark-only {
    display: none;
  }
  :global([data-theme='dark']) .light-only {
    display: none;
  }
  :global([data-theme='dark']) .dark-only {
    display: initial;
  }
</style>
